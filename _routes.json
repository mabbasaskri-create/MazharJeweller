{
  "version": 3,
  "routes": [
    {
      "src": "^/sitemap\\.xml$",
      "headers": {
        "Content-Type": "application/xml; charset=utf-8"
      }
    },
    {
      "src": "^/robots\\.txt$",
      "headers": {
        "Content-Type": "text/plain; charset=utf-8"
      }
    }
  ],
  "overrides": {
    "sitemap.xml": {
      "path": "/sitemap.xml"
    },
    "robots.txt": {
      "path": "/robots.txt"
    }
  }
}
